generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Scan {
  id             String   @id @default(cuid())
  productName    String
  grade          String
  gradeReason    String
  summary        String
  advice         String
  cleanCount     Int      @default(0)
  processedCount Int      @default(0)
  flaggedCount   Int      @default(0)
  source         String   @default("scan") // "scan" or "manual"
  imageData      String?
  results        String   // JSON string of ingredients array
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
